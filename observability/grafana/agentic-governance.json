      "title": "Request rate by status",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(agent_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}"
